{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "backend/api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/api/index.py"
    },
    {
      "src": "/(.*)",
      "headers": { "Cache-Control": "public, max-age=0, must-revalidate" },
      "dest": "/$1"
    }
  ],
  "env": {
    "PYTHONUNBUFFERED": "1"
  }
}
