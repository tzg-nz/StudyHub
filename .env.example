# ============================================
# Django 基础配置
# ============================================
DJANGO_SECRET_KEY=your-secret-key-here-please-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ============================================
# 数据库配置 (MySQL)
# ============================================
# 开发环境默认使用 SQLite，生产环境建议使用 MySQL
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=studyhub
# DB_USER=root
# DB_PASSWORD=your-password
# DB_HOST=localhost
# DB_PORT=3306

# ============================================
# CORS 配置 (生产环境必须设置)
# ============================================
# 开发环境允许所有来源，生产环境必须限制
CORS_ALLOW_ALL_ORIGINS=True
# 生产环境示例：
# CORS_ALLOW_ALL_ORIGINS=False
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# CSRF 配置 (生产环境必须设置)
# ============================================
# 开发环境默认值
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174
# 生产环境示例：
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ============================================
# 生产环境配置示例
# ============================================
# DJANGO_SECRET_KEY=生成一个50位随机字符串
# DEBUG=False
# ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com
# CORS_ALLOW_ALL_ORIGINS=False
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# CSRF_TRUSTED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com
# DB_ENGINE=django.db.backends.mysql
# DB_NAME=studyhub
# DB_USER=studyhub_user
# DB_PASSWORD=your-secure-password
# DB_HOST=localhost
# DB_PORT=3306
